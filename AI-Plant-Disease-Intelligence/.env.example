# ===========================================
# Plant Disease Identification System - Env
# ===========================================
# Copy to .env and fill values

# ---- Backend (FastAPI) ----
BACKEND_URL=http://localhost:8000
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Firebase ----
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ---- MongoDB (or use Firestore via Firebase) ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=plant_disease_db

# ---- AWS S3 (optional, if not using Firebase Storage) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=plant-disease-images

# ---- ML Model ----
MODEL_PATH=./model/saved_models/plant_disease_mobilenet.h5
TFLITE_MODEL_PATH=./model/saved_models/plant_disease_mobilenet.tflite
LABEL_JSON_PATH=./model/labels/class_names.json

# ---- Google Gemini (optional, for AI remedies) ----
GEMINI_API_KEY=

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
